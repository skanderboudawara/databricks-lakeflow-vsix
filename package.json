{
  "name": "databricks-job-viewer",
  "publisher": "skanderboudawara",
  "displayName": "Databricks Job Viewer",
  "description": "Visual DAG viewer for Databricks job YAML workflow files",
  "version": "0.2.1",
  "author": {
    "name": "Skander Boudawara",
    "email": "skander.education@proton.me"
  },
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skanderboudawara/databricks-lakeflow-vsix"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:databricksJobsTree",
    "workspaceContains:**/resources/**/*.yml",
    "workspaceContains:databricks.yml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "databricksJobViewer.openDag",
        "title": "Open Job DAG"
      },
      {
        "command": "databricksJobViewer.refresh",
        "title": "Refresh Jobs",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "databricks-jobs",
          "title": "Databricks Jobs",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "databricks-jobs": [
        {
          "type": "webview",
          "id": "databricksJobsTree",
          "name": "Job Workflows"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "databricksJobViewer.refresh",
          "when": "view == databricksJobsTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run lint && npm run bundle",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
